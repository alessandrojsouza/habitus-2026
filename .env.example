SECRET_KEY=sua_secret_key_super_segura_aqui

# Backend de Email:
# Em dev sem senha: django.core.mail.backends.console.EmailBackend
# Em prod/SMTP: django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

EMAIL_HOST_USER=seu_email_remetente@gmail.com
EMAIL_HOST_PASSWORD=sua_senha_de_app_16_letras_do_google
DEFAULT_FROM_EMAIL=seu_email_remetente@gmail.com

ALLOWED_HOSTS=seu-dominio-aws.com.br,localhost,127.0.0.1
SITE_URL=https://seu-dominio-aws.com.br

